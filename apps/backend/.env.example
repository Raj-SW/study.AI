# Server
NODE_ENV=development
PORT=3001

# Postgres (Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/study_copilot

# OpenAI — used directly or via AIDA proxy
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# Embeddings provider
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_PROVIDER_BASE_URL=https://api.openai.com/v1

# LLM provider: 'openai' goes direct, 'aida' routes through corporate proxy
LLM_PROVIDER=openai

# AIDA corporate proxy (required when LLM_PROVIDER=aida)
AIDA_BASE_URL=
AIDA_TEAM_NAME=testTeam
AIDA_USER_NAME=testUser
AIDA_TOOL=studyAI

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# CORS / rate limiting
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info

# Qdrant vector DB
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=study_copilot
QDRANT_API_KEY=
